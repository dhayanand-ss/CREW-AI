# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: ChromaDB OpenAI API Key (usually same as OPENAI_API_KEY)
CHROMA_OPENAI_API_KEY=your-openai-api-key-here

# AgentKit Workflow ID (for movie_qa_demo.py)
# Get your workflow ID from your AgentKit dashboard
AGENTKIT_WORKFLOW_ID=your-workflow-id-here

# Instructions:
# 1. Copy this file to .env
# 2. Replace placeholder values with your actual API keys and workflow IDs
# 3. Never commit the .env file to version control
